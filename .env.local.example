# Copiez ce fichier en .env.local et remplissez les valeurs (voir GUIDE.md)

# Jeton fourni par Vercel Blob Storage (voir étape 1 du guide)
BLOB_READ_WRITE_TOKEN=

# Mot de passe de votre choix pour accéder à /admin
ADMIN_PASSWORD=

# Chaîne aléatoire utilisée pour signer la session admin (voir étape 3 du guide)
ADMIN_SESSION_SECRET=

# Email affiché publiquement sur le site pour les contacts
NEXT_PUBLIC_CONTACT_EMAIL=chartreusecabinet@gmail.com
